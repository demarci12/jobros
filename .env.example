# Supabase (EU régió)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # CSAK szerver oldal, sosem kliens

# --- Auth providerek (Supabase Auth-ban konfigurálva; ezek a hozzájuk tartozó OAuth appok) ---
# Google OAuth (a naptár-connectorral megosztható projekt)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Apple Sign in
APPLE_SERVICE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- App Store connectorok ---
# A tenant-szintű titkok (Billingo kulcs, Stripe kulcs, Barion POS, stb.) NEM ide jönnek,
# hanem az App Store telepítéskor a Supabase Vaultba (installed_apps.secret_ref).
# Itt csak a platform-szintű, közös kulcsok vannak:

# Térkép
NEXT_PUBLIC_MAPBOX_TOKEN=

# Email/SMS feladó (platform default; tenant felülírhatja az app store-ban)
RESEND_API_KEY=
INFOBIP_API_KEY=

# Stripe platform (ha connect-modellt használsz a tenantokhoz)
STRIPE_PLATFORM_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Dispatch (self-host) ---
OSRM_URL=http://localhost:5000        # OSRM Table (utazási mátrix), EU OSM
VROOM_URL=http://localhost:3000       # vroom-express (VRP solver)

# --- SaaS-előfizetés (Stripe Billing — a tenant fizet NEKÜNK) ---
STRIPE_BILLING_SECRET_KEY=
STRIPE_BILLING_WEBHOOK_SECRET=
# A saját Billingo-fiókunk a NAV-os előfizetési számlákhoz (dogfooding) → Vaultban

# Cron security (Vercel Cron → API routes)
CRON_SECRET=replace_with_random_secret_32chars

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
