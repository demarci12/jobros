# ============================================================
# Jobro — Production Environment Variables
# Vercel Dashboard → Settings → Environment Variables-ba
# ============================================================

# ── Supabase (EU régió) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://qnahbwwecposxaxmfsjr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<Supabase Dashboard → Settings → API → anon public>
SUPABASE_SERVICE_ROLE_KEY=<Supabase Dashboard → Settings → API → service_role SECRET>
# ⚠️  A service_role kulcs SOSEM kerülhet NEXT_PUBLIC_ előtaggal!

# ── Térkép ───────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=<Mapbox Dashboard → Tokens → Default public token>

# ── SMS (Infobip) ─────────────────────────────────────────────
INFOBIP_API_KEY=<Infobip Dashboard → API Keys>
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_SENDER=Jobro

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=<Resend Dashboard → API Keys>
RESEND_FROM_EMAIL=noreply@jobro.hu

# ── Stripe Billing (SaaS előfizetés — a tenant fizet NEKÜNK) ─
STRIPE_BILLING_SECRET_KEY=sk_live_...
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...
# Stripe Webhook endpoint: https://jobro.hu/api/webhooks/stripe-billing
# Esemény: customer.subscription.updated, customer.subscription.deleted,
#          invoice.payment_succeeded, invoice.payment_failed

# ── Dispatch (self-host, EU) ──────────────────────────────────
# OSRM + VROOM külön konténer-hoston (Fly.io / Railway / VPS)
OSRM_URL=https://osrm.jobro.hu
VROOM_URL=https://vroom.jobro.hu

# ── Cron security ─────────────────────────────────────────────
# Generálj 32+ karakteres random titkot: openssl rand -hex 32
CRON_SECRET=<openssl rand -hex 32>
# Vercel Cron a következő endpoint-okat hívja (vercel.json):
#   GET /api/cron/service-reminders  — 0 7 * * * (08:00 CET)
#   GET /api/cron/billing-lifecycle  — 0 6 * * * (07:00 CET)
# A kérés Authorization: Bearer <CRON_SECRET> fejléccel érkezik.

# ── Auth providerek ───────────────────────────────────────────
# Supabase Dashboard → Authentication → Providers-ben kell beállítani;
# az alábbi értékeket ott add meg (nem Next.js env-ben):
#   Google OAuth Client ID + Secret
#   Apple Service ID + Team ID + Key ID + Private Key

# ── Tenant-szintű titkok (NEM ide) ───────────────────────────
# Billingo API kulcs, Stripe Connect kulcsok, SimplePay, stb.
# → App Store telepítés → Supabase Vault (installed_apps.secret_ref)
# → Supabase Dashboard → Vault → New Secret
